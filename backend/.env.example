# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lastmile_db"

# Auth
JWT_SECRET="your_super_secret_jwt_key_change_this"

# Server
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Email (Nodemailer - Gmail example)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="LastMile Delivery <your_email@gmail.com>"

# SMS (optional - choose one provider)
# Leave SMS_API_KEY blank to disable SMS (emails will still be sent)
SMS_PROVIDER="fast2sms"       # Options: fast2sms | twilio
SMS_API_KEY=""                # Fast2SMS API key (get free at fast2sms.com)

# If using Twilio instead:
# SMS_PROVIDER="twilio"
# SMS_API_KEY=""              # Not used for twilio
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM="+1234567890"
