// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  AGENT
  ADMIN
}

enum OrderType {
  B2B
  B2C
}

enum PaymentType {
  PREPAID
  COD
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]        @relation("CustomerOrders")
  createdOrders Order[]        @relation("AdminCreatedOrders")
  agentProfile  DeliveryAgent?
}

model Zone {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  areas        Area[]
  pickupOrders Order[]         @relation("PickupZone")
  dropOrders   Order[]         @relation("DropZone")
  agents       DeliveryAgent[]
  fromRateCards RateCard[]     @relation("FromZone")
  toRateCards   RateCard[]     @relation("ToZone")
}

model Area {
  id      String @id @default(cuid())
  name    String
  pincode String @unique
  zoneId  String
  zone    Zone   @relation(fields: [zoneId], references: [id])
}

model RateCard {
  id           String    @id @default(cuid())
  orderType    OrderType
  fromZoneId   String
  toZoneId     String
  ratePerKg    Float
  codSurcharge Float     @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fromZone Zone @relation("FromZone", fields: [fromZoneId], references: [id])
  toZone   Zone @relation("ToZone",   fields: [toZoneId],   references: [id])

  @@unique([orderType, fromZoneId, toZoneId])
}

model DeliveryAgent {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id])
  latitude    Float?
  longitude   Float?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())

  orders Order[]
}

model Order {
  id         String @id @default(cuid())
  trackingId String @unique @default(cuid())

  customerId  String
  customer    User   @relation("CustomerOrders", fields: [customerId], references: [id])

  createdById String?
  createdBy   User?   @relation("AdminCreatedOrders", fields: [createdById], references: [id])

  agentId String?
  agent   DeliveryAgent? @relation(fields: [agentId], references: [id])

  pickupAddress String
  pickupPincode String
  pickupZoneId  String
  pickupZone    Zone   @relation("PickupZone", fields: [pickupZoneId], references: [id])

  dropAddress String
  dropPincode String
  dropZoneId  String
  dropZone    Zone   @relation("DropZone", fields: [dropZoneId], references: [id])

  length           Float
  breadth          Float
  height           Float
  actualWeight     Float
  volumetricWeight Float
  chargeableWeight Float

  orderType   OrderType
  paymentType PaymentType
  status      OrderStatus @default(PENDING)

  baseCharge   Float
  codSurcharge Float @default(0)
  totalCharge  Float

  scheduledDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trackingHistory TrackingEvent[]
}

model TrackingEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  note      String?
  actorId   String?
  actorRole Role?
  createdAt DateTime    @default(now())
}
